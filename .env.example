# Cliente (Vite)
# Exemplo produção com proxy Nginx no mesmo domínio:
VITE_WS_URL=wss://example.com/ws

# Servidor WebSocket
PORT=3011
TICK_RATE=30

# Deploy script (frontend + backend)
DEPLOY_DIR=/var/www/omnizap.xyz/current
DIST_DIR=/root/nebula/dist
NGINX_BIN=nginx
SYSTEMCTL_BIN=systemctl
SERVICE_NAME=nginx
BACKEND_SERVICE_NAME=nebula-ws
RESTART_BACKEND=1
